---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangPaths, useTranslations } from "../../i18n/utils";
import ProjekterIsland from "../../components/ProjekterIsland";
import "../../pagesCSS/Projekter.css";

export function getStaticPaths() {
  return getLangPaths();
}

const { lang } = Astro.params;
const t = useTranslations(lang);
const pk = t("projekter");
---

<BaseLayout lang={lang} isHome={false} title={"Projekter — Nelson Peña"}>
  <ProjekterIsland pk={pk} lang={lang} client:load />
</BaseLayout>

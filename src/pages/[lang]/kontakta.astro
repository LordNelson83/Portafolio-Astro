---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangPaths, useTranslations } from "../../i18n/utils";
import "../../pagesCSS/Kontakta.css";

const FEEDBACK_LABELS = {
  sv: { eyebrow: "Feedback", title: "Vad tycker du?", sub: "Har du några tankar om portfoliot? Jag läser allt.", placeholder: "Skriv din feedback här...", rolePlaceholder: "Din roll (valfritt)", emailPlaceholder: "E-post (valfritt, om du vill ha svar)", submit: "Skicka", success: "Tack för din feedback!", error: "Något gick fel, försök igen." },
  en: { eyebrow: "Feedback", title: "What do you think?", sub: "Any thoughts on the portfolio? I read everything.", placeholder: "Write your feedback here...", rolePlaceholder: "Your role (optional)", emailPlaceholder: "Email (optional, if you want a reply)", submit: "Send", success: "Thanks for your feedback!", error: "Something went wrong, try again." },
  es: { eyebrow: "Feedback", title: "¿Qué opinas?", sub: "¿Alguna idea sobre el portafolio? Leo todo.", placeholder: "Escribe tu feedback aquí...", rolePlaceholder: "Tu rol (opcional)", emailPlaceholder: "Correo (opcional, si quieres respuesta)", submit: "Enviar", success: "¡Gracias por tu feedback!", error: "Algo salió mal, intenta de nuevo." },
};


export function getStaticPaths() {
  return getLangPaths();
}

const { lang } = Astro.params;
const feedbackLabels = FEEDBACK_LABELS[lang] || FEEDBACK_LABELS.sv;
const t = useTranslations(lang);

const statsItems  = t("contact", "statsItems");
const pitchPoints = t("contact", "pitchPoints");

const CV_FILES = {
  sv: { href: "/CV_Nelson_Pena.pdf",           download: "CV_Nelson_Pena.pdf",           label: "CV · Nelson Peña · Svenska" },
  en: { href: "/Nelson_Pena_CV_English.pdf",    download: "Nelson_Pena_CV_English.pdf",   label: "CV · Nelson Peña · English" },
  es: { href: "/Nelson_Pena_CV_Español.pdf",    download: "Nelson_Pena_CV_Español.pdf",   label: "CV · Nelson Peña · Español" },
};
const cv = CV_FILES[lang] ?? CV_FILES.sv;

const SOCIAL = [
  { id: "linkedin", label: t("contact", "linkedin"), sub: t("contact", "linkedinSub"), href: "https://www.linkedin.com/in/nelson-pe%C3%B1a-21881412a/" },
  { id: "github",   label: t("contact", "github"),   sub: t("contact", "githubSub"),   href: "https://github.com/LordNelson83" },
];
---

<BaseLayout lang={lang} isHome={true} title={"Kontakt — Nelson Peña"}>
  <div class="kt-page">
    <div class="kt-grain" aria-hidden="true" />
    <div class="kt-bg-word" aria-hidden="true">Tack</div>

    <header class="kt-hero js-reveal">
      <p class="kt-hero__eyebrow">{t("contact", "eyebrow")}</p>
      <h1 class="kt-hero__h1">{t("contact", "h1")}</h1>
      <p class="kt-hero__sub">{t("contact", "sub")}</p>
      <div class="kt-hero__line" aria-hidden="true" />
    </header>

    <div class="kt-stats" role="list">
      {statsItems.map((s, i) => (
        <div class="kt-stat js-reveal" role="listitem" style={"--delay:" + (i * 0.1) + "s"}>
          <span class="kt-stat__value">{s.value}</span>
          <span class="kt-stat__label">{s.label}</span>
        </div>
      ))}
    </div>

    <div class="kt-body">
      <div class="kt-pitch js-reveal">
        <p class="kt-pitch__label">{t("contact", "pitchLabel")}</p>
        <ul class="kt-pitch__list">
          {pitchPoints.map((point) => (
            <li class="kt-pitch__item">{point}</li>
          ))}
        </ul>
      </div>

      <div class="kt-links">
        <a href={"mailto:" + t("contact", "emailSub")} class="kt-link kt-link--email js-reveal">
          <span class="kt-link__label">{t("contact", "email")}</span>
          <span class="kt-link__sub">{t("contact", "emailSub")}</span>
          <span class="kt-link__arrow" aria-hidden="true">↗</span>
        </a>

        {SOCIAL.map((s, i) => (
          <a href={s.href} target="_blank" rel="noopener noreferrer"
            class="kt-link js-reveal" style={"--delay:" + ((i + 1) * 0.1) + "s"}>
            <span class="kt-link__label">{s.label}</span>
            <span class="kt-link__sub">{s.sub}</span>
            <span class="kt-link__arrow" aria-hidden="true">↗</span>
          </a>
        ))}

        <a href={cv.href} download={cv.download} class="kt-link kt-link--cv js-reveal">
          <span class="kt-link__icon" aria-hidden="true">↓</span>
          <span class="kt-link__label">{cv.label}</span>
        </a>
      </div>
    </div>
  </div>

    <div class="kt-feedback js-reveal">
      <p class="kt-feedback__eyebrow">{feedbackLabels.eyebrow}</p>
      <h2 class="kt-feedback__title">{feedbackLabels.title}</h2>
      <p class="kt-feedback__sub">{feedbackLabels.sub}</p>
      <form
        name="portfolio-feedback"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="kt-feedback__form"
        id="feedback-form"
      >
        <input type="hidden" name="form-name" value="portfolio-feedback" />
        <p class="kt-feedback__hidden">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>
        <textarea
          name="message"
          required
          rows="4"
          placeholder={feedbackLabels.placeholder}
        ></textarea>
        <div class="kt-feedback__row">
          <input type="text" name="role" placeholder={feedbackLabels.rolePlaceholder} />
          <input type="email" name="email" placeholder={feedbackLabels.emailPlaceholder} />
        </div>
        <button type="submit">{feedbackLabels.submit}</button>
        <p class="kt-feedback__status" id="feedback-status" role="status" aria-live="polite"></p>
      </form>
    </div>
</BaseLayout>

<script define:vars={{ feedbackLabels }}>
  const form = document.getElementById("feedback-form");
  const status = document.getElementById("feedback-status");
  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      try {
        await fetch("/", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: new URLSearchParams(data).toString(),
        });
        status.textContent = feedbackLabels.success;
        form.reset();
      } catch (err) {
        status.textContent = feedbackLabels.error;
      }
    });
  }
</script>

<script>
  const obs = new IntersectionObserver(
    (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add("is-visible")),
    { threshold: 0.08 }
  );
  document.querySelectorAll(".js-reveal").forEach(el => obs.observe(el));
  setTimeout(() => document.querySelectorAll(".js-reveal").forEach(el => el.classList.add("is-visible")), 1200);
</script>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLangPaths, useTranslations } from "../../i18n/utils";
import "../../pagesCSS/Home.css";

export function getStaticPaths() {
  return getLangPaths();
}

const { lang } = Astro.params;
const t = useTranslations(lang);

const FEATURED_TILE = {
  num: "01",
  label: "Byraanalys",
  sub: "Fortnox · UX Research · Hi-Fi Prototyp",
  tag: "Examensarbete 2025-2026",
  path: "/" + lang + "/projekter/byraanalys",
  accent: "#00a6b4",
};

const TILES = [
  { num:"02", label:"UX/UI Design", sub:"Research · Prototyping · System",                  path:"/" + lang + "/uxuidesign",       accent:"#ffffff" },
  { num:"03", label:"Projekter",    sub:"Tidningsmagasin · Gymplanerare · E-handelsprojekt", path:"/" + lang + "/grafiskproduktion", accent:"#ffa205" },
  { num:"04", label:"Cross Media",  sub:"Print · Editorial · Branding",                     path:"/" + lang + "/crossmedia",       accent:"#ffffff" },
  { num:"05", label:"3D Print",     sub:"Shapr3D · Modelling · Production",                 path:"/" + lang + "/threedprint",      accent:"#ffa205" },
];
---

<BaseLayout lang={lang} isHome={true} title={t("home", "title") + " — Nelson Pena"}>
  <main id="main-content" class="home-page">

    <section class="home-hero" id="hero-section" aria-label="Hero - Nelson Pena">
      <img class="hero-photo" src="/images/me.webp" alt="Nelson Pena, Product and UX/UI Designer" />
      <div class="hero-overlay" aria-hidden="true" />
      <div class="hero-grain"   aria-hidden="true" />
      <span class="hero-index" aria-hidden="true">2026</span>
      <p class="hero-role" aria-hidden="true">Product and UX/UI Designer</p>
      <div class="hero-content">
        <h1 class="hero-name">
          <span class="hero-name__first">Nelson&nbsp;</span>
          <span class="hero-name__last">Pe&#241;a</span>
        </h1>
      </div>
      <div class="hero-bio">
        <h2 class="hero-bio__headline">{t("home", "heroHeadline")}</h2>
        <p class="hero-bio__subtext">{t("home", "heroSubtext")}</p>
        <span class="hero-bio__tagline">{t("home", "heroTagline")}</span>
        <a href={"/" + lang + "/projekter/byraanalys"} class="hero-bio__cta">
          {t("home", "heroCta")} <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="hero-scroll-hint" aria-hidden="true">
        <span />
        <p>Scroll</p>
      </div>
    </section>

    <section class="home-work" aria-labelledby="work-heading">
      <div class="home-work__header">
        <p class="home-work__eyebrow">{t("home", "eyebrow")}</p>
        <h2 class="home-work__title" id="work-heading">360&#176; Design</h2>
      </div>
      <ul class="home-work__grid" role="list">
        <li class="tile tile--featured js-tile" style={"--tile-accent:" + FEATURED_TILE.accent + ";--delay:0s"}>
          <a href={FEATURED_TILE.path} class="tile__link tile__link--featured">
            <div class="tile__featured-left">
              <span class="tile__number" aria-hidden="true">{FEATURED_TILE.num}</span>
              <div class="tile__featured-texts">
                <span class="tile__label">{FEATURED_TILE.label}</span>
                <span class="tile__sub">{FEATURED_TILE.sub}</span>
              </div>
            </div>
            <div class="tile__featured-right">
              <span class="tile__featured-tag">{FEATURED_TILE.tag}</span>
              <span class="tile__featured-cta">L&#228;s case study</span>
            </div>
          </a>
        </li>
        {TILES.map((tile, i) => (
          <li class="tile js-tile" style={"--tile-accent:" + tile.accent + ";--delay:" + ((i + 1) * 0.1) + "s"}>
            <a href={tile.path} class="tile__link">
              <span class="tile__number" aria-hidden="true">{tile.num}</span>
              <span class="tile__label">{tile.label}</span>
              <span class="tile__sub">{tile.sub}</span>
              <span class="tile__arrow" aria-hidden="true">&#8594;</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="home-contact" aria-label="Kontakt">
      <p class="home-contact__text">
        {t("home", "contact")} <em>{t("home", "contactEm")}</em>
      </p>
      <a href={"/" + lang + "/kontakta"} class="home-contact__btn">
        {t("home", "contactBtn")}
      </a>
    </section>

  </main>
</BaseLayout>

<script>
  const photo = document.querySelector(".hero-photo");
  if (photo) {
    window.addEventListener("scroll", () => {
      photo.style.transform = "translateY(" + (window.scrollY * 0.25) + "px)";
    }, { passive: true });
  }
  const tiles = document.querySelectorAll(".js-tile");
  const obs = new IntersectionObserver(
    (entries) => entries.forEach(e => e.isIntersecting && e.target.classList.add("tile--visible")),
    { threshold: 0.01, rootMargin: "0px 0px -10% 0px" }
  );
  tiles.forEach(el => obs.observe(el));
  setTimeout(() => tiles.forEach(el => el.classList.add("tile--visible")), 1200);
</script>







